# HTAccess para StudioLogos Biblioteca — SPA Routing + MIME Types

# SPA fallback — todas as rotas vão para index.html
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Não reescrever arquivos e diretórios existentes
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Redirecionar tudo para index.html
  RewriteRule ^ index.html [QSA,L]
</IfModule>

# Fallback para servidores sem mod_rewrite
ErrorDocument 404 /index.html

# MIME types corretos
<IfModule mod_mime.c>
  AddType application/javascript .js .mjs
  AddType text/css .css
  AddType image/svg+xml .svg
  AddType application/manifest+json .webmanifest
</IfModule>

# Headers de segurança e cache
<IfModule mod_headers.c>
  <FilesMatch "\.js$">
    Header set Content-Type "application/javascript; charset=utf-8"
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
  <FilesMatch "\.css$">
    Header set Content-Type "text/css; charset=utf-8"
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff2?)$">
    Header set Cache-Control "max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "^index\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>
</IfModule>
