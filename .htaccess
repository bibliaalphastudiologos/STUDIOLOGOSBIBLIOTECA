# HTAccess para StudioLogos Biblioteca
# Garante MIME types corretos para JS e CSS

Options -MultiViews

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^api/mercadopago-webhook/?$ /api/mercadopago-webhook/index.php [L]
  RewriteRule ^api/gutenberg-proxy/?$ /api/gutenberg-proxy/index.php [L]
  RewriteRule ^index\.html$ - [L]
  RewriteRule ^sw\.js$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>

<IfModule mod_headers.c>
  # JavaScript modules - tipo correto para import/export
  <FilesMatch "\.js$">
    Header set Content-Type "application/javascript; charset=utf-8"
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
  
  # CSS
  <FilesMatch "\.css$">
    Header set Content-Type "text/css; charset=utf-8"
    Header set X-Content-Type-Options "nosniff"
  </FilesMatch>
  
  # HTML
  <FilesMatch "\.html$">
    Header set Content-Type "text/html; charset=utf-8"
  </FilesMatch>
</IfModule>

# Fallback final para SPA caso mod_rewrite esteja indisponível
ErrorDocument 404 /index.html

# Garantir que arquivos .js sejam tratados como módulos
<IfModule mod_mime.c>
  AddType application/javascript .js
  AddType text/css .css
</IfModule>
