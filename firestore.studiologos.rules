rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/studio_users/$(request.auth.uid));
    }

    function isStudioAdmin() {
      return signedIn()
        && exists(/databases/$(database)/documents/studio_users/$(request.auth.uid))
        && userDoc().data.isAdmin == true;
    }

    function isOwnStudioUser(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isSelfPendingProfile() {
      return request.resource.data.email == request.auth.token.email
        && request.resource.data.status == 'pending'
        && request.resource.data.payment_status == 'pending'
        && request.resource.data.access_status == 'blocked'
        && request.resource.data.isAdmin == false
        && (!('manual_access' in request.resource.data) || request.resource.data.manual_access == false);
    }

    function isValidLeadInterest(value) {
      return value in [
        'Bíblia Alpha',
        'E-books de Teologia',
        'Filosofia',
        'Psicanálise',
        'Biblioteca completa',
        'Assinatura Studio Logos'
      ];
    }

    function isValidLeadStatus(value) {
      return value in ['Novo lead', 'Em conversa', 'Interessado', 'Pagou', 'Aprovado'];
    }

    function isValidPublicLeadCreate() {
      return request.resource.data.keys().hasOnly([
          'nome',
          'email',
          'whatsapp',
          'interesse',
          'lgpdConsent',
          'source',
          'status',
          'paymentLink',
          'whatsappUrl',
          'emailFunnelStatus',
          'whatsappFunnelStatus',
          'emailFunnel',
          'whatsappSequence',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.nome is string
        && request.resource.data.email is string
        && request.resource.data.whatsapp is string
        && request.resource.data.source is string
        && request.resource.data.lgpdConsent == true
        && request.resource.data.status == 'Novo lead'
        && isValidLeadInterest(request.resource.data.interesse);
    }

    match /studio_users/{userId} {
      allow read: if isOwnStudioUser(userId) || isStudioAdmin();
      allow create: if (isOwnStudioUser(userId) && isSelfPendingProfile()) || isStudioAdmin();
      allow update: if (
          isOwnStudioUser(userId)
          && request.resource.data.diff(resource.data).changedKeys()
            .hasOnly(['nome', 'foto', 'email', 'updatedAt'])
        ) || isStudioAdmin();
      allow delete: if isStudioAdmin();

      match /notes/{noteId} {
        allow read, write: if isOwnStudioUser(userId) || isStudioAdmin();
      }
    }

    match /studio_payment_access/{email} {
      allow read: if (signedIn() && request.auth.token.email == email) || isStudioAdmin();
      allow write: if isStudioAdmin();
    }

    match /studio_payments/{paymentId} {
      allow read: if isStudioAdmin();
      allow write: if false;
    }

    match /studio_leads/{leadId} {
      allow create: if isValidPublicLeadCreate();
      allow read, delete: if isStudioAdmin();
      allow update: if isStudioAdmin()
        && (!('status' in request.resource.data) || isValidLeadStatus(request.resource.data.status));
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
